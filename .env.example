# Copy to .env and fill in:  cp .env.example .env
# Loaded automatically on startup (see cspdx/__init__.py).
# Real shell env vars override these (so Docker / Cloud Run --set-env-vars wins).

# --- Secrets ---
GOOGLE_API_KEY=          # Gemini API key (categorization + chat)
ADMIN_TOKEN=             # guards /admin/* (rebuild + reload); empty disables them

# --- Google auth ---
GDOC_AUTH_MODE=oauth     # oauth (credentials.json/token.json) | service_account
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json  # only for service_account mode

# --- Chat reload hook ---
CSPDX_RELOAD_URL=http://127.0.0.1:8080/admin/reload

# --- Server paths (rarely changed) ---
SITE_DIR=build/site
SECTIONS_PATH=build/sections.json
CONTENT_YAML=content.yaml
BUILD_META_PATH=build/build_meta.json
STATIC_DIR=static    # copied into build/site on build; PDFs live in static/files/
