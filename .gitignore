credentials.json
token.json
# Local config/secrets; copy .env.example -> .env (the example stays tracked).
.env
*.pyc
__pycache__
.venv
logs/
# build/ is fully regenerated by `cspdx build` (from the Google Docs, static/,
# and content.yaml), so its output isn't tracked. The one exception is the LLM
# categorization cache, kept to avoid re-paying Gemini calls and to keep
# categories stable across rebuilds. NB: ignore build/* (contents), not build/
# (the dir), so the negation below can re-include a file under it.
build/*
!build/category_cache.json
