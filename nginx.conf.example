# nginx in front of FastAPI (which runs on 127.0.0.1:8080 via systemd or pm2).
# Run `python -m cspdx.cli build` on a schedule to refresh build/site/.

server {
    listen 80;
    server_name web.cs.pdx.edu;

    # Static pages and landing
    root /var/www/pdx-cs-site/build/site;
    index index.html;

    # Chat API + UI proxied to the FastAPI process
    location /ask {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_read_timeout 120s;
    }

    # Prefix (no trailing slash) so it covers both GET /admin and the
    # POST /admin/rebuild + /admin/upload endpoints.
    location /admin {
        # Restrict to campus or specific IPs in production
        proxy_pass http://127.0.0.1:8080;
        # Allow PDF uploads (the app caps the file itself at 10 MB).
        client_max_body_size 11m;
    }

    # Admin-uploaded PDFs, served straight from disk (only PDFs are stored here).
    # The FastAPI app writes them here; nginx need not proxy these requests.
    location /files/ {
        alias /var/www/pdx-cs-site/files/;
        try_files $uri =404;
        add_header Cache-Control "public, max-age=300";
    }

    location / {
        try_files $uri $uri/ =404;
    }
}
