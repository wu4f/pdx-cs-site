# nginx in front of the FastAPI app (127.0.0.1:8080 via systemd/pm2).
#
# Split of responsibilities:
#   * nginx serves ALL static assets in build/site/ directly from disk
#     (landing page, section pages, /files/*.pdf, ...) -- fast, no Python.
#   * Only the dynamic endpoints are proxied to the Python app:
#       /ask                                  chatbot API (POST) + chat UI (GET)
#       /admin /admin/rebuild /admin/upload   admin page + rebuild + PDF upload
#   * Run `python -m cspdx.cli build` on a schedule to refresh build/site/.

upstream cspdx_app {
    server 127.0.0.1:8080;
}

server {
    listen 80;
    server_name web.cs.pdx.edu;

    root /var/www/pdx-cs-site/build/site;
    index index.html;

    # Common proxy settings, inherited by the proxied locations below. (A
    # location that sets its own proxy_set_header would drop these, so the
    # proxy locations deliberately set none of their own except sizes/timeouts.)
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 120s;

    # --- Dynamic: proxied to the Python app ---

    # Chatbot API (POST /ask) and chat UI (GET /ask/).
    location /ask {
        proxy_pass http://cspdx_app;
    }

    # Admin: GET /admin, POST /admin/rebuild, POST /admin/upload, /admin/reload.
    location /admin {
        # Restrict to campus / specific IPs in production, e.g.:
        #   allow 131.252.0.0/16; deny all;
        client_max_body_size 11m;   # PDF uploads (the app caps the file at 10 MB)
        proxy_pass http://cspdx_app;
    }

    # --- Static: served by nginx straight from build/site/ ---

    # Uploaded PDFs. `cspdx build` copies static/files/ -> build/site/files/,
    # so these are plain files under the site root; just add caching here.
    location /files/ {
        add_header Cache-Control "public, max-age=300";
        try_files $uri =404;
    }

    # Everything else: landing page, section pages, and any other assets.
    location / {
        try_files $uri $uri/ =404;
    }
}
